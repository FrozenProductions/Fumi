        "autoprefixer": "^10.4.20",
        "esbuild": "^0.27.4",
        "postcss": "^8.4.49",
        "tailwindcss": "^3.4.16",
        "typescript": "^6.0.2",
        "vite": "npm:@voidzero-dev/vite-plus-core@latest",
