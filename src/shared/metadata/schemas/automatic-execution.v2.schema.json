{
    "$defs": {
        "AutomaticExecutionCursorState": {
            "properties": {
                "column": {
                    "format": "int64",
                    "type": "integer"
                },
                "line": {
                    "format": "int64",
                    "type": "integer"
                },
                "scrollTop": {
                    "format": "double",
                    "type": "number"
                }
            },
            "required": ["line", "column", "scrollTop"],
            "type": "object"
        },
        "AutomaticExecutionScriptState": {
            "properties": {
                "cursor": {
                    "$ref": "#/$defs/AutomaticExecutionCursorState"
                },
                "fileName": {
                    "type": "string"
                },
                "id": {
                    "type": "string"
                }
            },
            "required": ["id", "fileName", "cursor"],
            "type": "object"
        },
        "MetadataKind": {
            "enum": ["workspace", "automatic_execution", "accounts"],
            "type": "string"
        }
    },
    "$id": "https://fumi.app/schemas/automatic-execution.v2.schema.json",
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "additionalProperties": true,
    "properties": {
        "$schema": {
            "type": "string"
        },
        "activeScriptId": {
            "default": null,
            "type": ["string", "null"]
        },
        "createdAt": {
            "format": "int64",
            "type": "integer"
        },
        "kind": {
            "$ref": "#/$defs/MetadataKind"
        },
        "migratedFromVersion": {
            "default": null,
            "format": "uint8",
            "maximum": 255,
            "minimum": 0,
            "type": ["integer", "null"]
        },
        "scripts": {
            "default": [],
            "items": {
                "$ref": "#/$defs/AutomaticExecutionScriptState"
            },
            "type": "array"
        },
        "updatedAt": {
            "format": "int64",
            "type": "integer"
        },
        "version": {
            "format": "uint8",
            "maximum": 255,
            "minimum": 0,
            "type": "integer"
        },
        "writtenByAppVersion": {
            "type": "string"
        }
    },
    "required": [
        "$schema",
        "kind",
        "version",
        "createdAt",
        "updatedAt",
        "writtenByAppVersion"
    ],
    "title": "PersistedAutomaticExecutionDocumentV2",
    "type": "object"
}
