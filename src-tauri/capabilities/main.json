{
    "$schema": "../gen/schemas/desktop-schema.json",
    "identifier": "main",
    "description": "enables the main desktop window capabilities",
    "windows": ["main"],
    "permissions": [
        "core:default",
        "core:window:allow-start-dragging",
        "core:window:allow-toggle-maximize",
        "dialog:default",
        "clipboard-manager:default"
    ]
}
