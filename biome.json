{
    "$schema": "https://biomejs.dev/schemas/2.4.10/schema.json",
    "vcs": {
        "enabled": true,
        "clientKind": "git",
        "useIgnoreFile": true
    },
    "files": {
        "ignoreUnknown": false
    },
    "formatter": {
        "enabled": true,
        "indentStyle": "space",
        "indentWidth": 4,
        "lineEnding": "lf"
    },
    "linter": {
        "enabled": true,
        "rules": {
            "recommended": true,
            "style": {
                "noDefaultExport": "error",
                "noEnum": "error",
                "noNonNullAssertion": "error",
                "useConsistentTypeDefinitions": {
                    "level": "error",
                    "options": {
                        "style": "type"
                    }
                },
                "useImportType": {
                    "level": "error",
                    "options": {
                        "style": "auto"
                    }
                },
                "useNodejsImportProtocol": "error"
            },
            "suspicious": {
                "noExplicitAny": "off",
                "noUnknownAtRules": "off"
            },
            "a11y": {
                "noStaticElementInteractions": "off",
                "useKeyWithClickEvents": "off"
            }
        }
    },
    "javascript": {
        "formatter": {
            "quoteStyle": "double",
            "jsxQuoteStyle": "double"
        }
    },
    "overrides": [
        {
            "includes": ["src/**/*.ts", "src/**/*.tsx"],
            "linter": {
                "rules": {
                    "style": {
                        "noRestrictedImports": {
                            "level": "error",
                            "options": {
                                "paths": {
                                    "@tauri-apps/api": "Use the wrappers in src/lib/platform/ instead of importing Tauri APIs directly in application code."
                                },
                                "patterns": [
                                    {
                                        "group": ["@tauri-apps/api/**"],
                                        "message": "Use the wrappers in src/lib/platform/ instead of importing Tauri APIs directly in application code."
                                    },
                                    {
                                        "group": ["@tauri-apps/plugin-*"],
                                        "message": "Use the wrappers in src/lib/platform/ instead of importing Tauri plugins directly in application code."
                                    }
                                ]
                            }
                        }
                    }
                }
            }
        },
        {
            "includes": [
                "src/lib/platform/**/*.ts",
                "src/lib/platform/**/*.tsx"
            ],
            "linter": {
                "rules": {
                    "style": {
                        "noRestrictedImports": "off"
                    }
                }
            }
        },
        {
            "includes": ["tailwind.config.js", "vite.config.mts"],
            "linter": {
                "rules": {
                    "style": {
                        "noDefaultExport": "off"
                    }
                }
            }
        }
    ],
    "assist": {
        "enabled": true,
        "actions": {
            "source": {
                "organizeImports": "on"
            }
        }
    }
}
